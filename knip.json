{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "src/background/index.ts",
    "src/content/linkedinOverlay.ts",
    "src/content/linkedinCompanionSafety.ts",
    "src/pages/mobile/main.tsx",
    "src/pages/chatbotWeb/renderChatbotSurface.tsx",
    "src/pages/dashboard/main.tsx",
    "src/pages/welcome/main.tsx",
    "src/pages/help/main.tsx",
    "src/pages/integrations/main.tsx",
    "tests/**/*.test.ts",
    "tests/helpers/**/*.ts"
  ],
  "project": ["src/**/*.ts", "src/**/*.tsx"],
  "ignoreExportsUsedInFile": {
    "interface": true,
    "type": true
  },
  "ignoreIssues": {
    "src/types/domain.ts": ["types"]
  },
  "ignore": ["android/**", "dist/**", ".cursor/**", "scripts/**", "node_modules/**"],
  "ignoreDependencies": ["@capacitor/android", "@capacitor/core", "@capacitor/ios", "knip"]
}
