{
  "name": "brandops-extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:mobile": "vite --open /mobile.html",
    "bridge:proxy": "node scripts/bridge-proxy.mjs",
    "build": "tsc -b && vite build && node scripts/copy-manifest.mjs",
    "build:mobile": "tsc -b && vite build",
    "preview": "vite preview",
    "android:add": "cap add android",
    "android:sync": "cap sync android",
    "android:open": "cap open android",
    "android:run": "cap run android",
    "ios:add": "cap add ios",
    "ios:sync": "cap sync ios",
    "ios:open": "cap open ios",
    "ios:run": "cap run ios",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:perf": "vitest run tests/performance --reporter=verbose",
    "typecheck": "tsc -b",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "check": "npm run typecheck && npm run lint",
    "knip": "knip --no-exit-code --no-config-hints",
    "verify:dist": "node scripts/verify-dist.mjs",
    "package:release": "node scripts/package-release.mjs",
    "release": "npm run check && npm run build && npm run verify:dist && npm run package:release"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/ios": "^8.3.1",
    "clsx": "^2.1.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.543.0",
    "motion": "^12.38.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.1",
    "@eslint/js": "^9.35.0",
    "@types/chrome": "^0.1.24",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.43.0",
    "@typescript-eslint/parser": "^8.43.0",
    "@vitejs/plugin-react": "^5.0.2",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.35.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "knip": "^5.88.1",
    "postcss": "^8.5.6",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.43.0",
    "vite": "^7.1.3",
    "vitest": "^4.1.4"
  }
}
