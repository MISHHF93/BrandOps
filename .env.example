# Copy to ".env.local" in the repo root (gitignored) for local OAuth and other Vite secrets.
# See docs/chrome-web-store-listing.md for redirect URIs and store listing copy.
#
# Local dev is fixed to http://localhost:5173 (vite.config.ts strictPort). Free that port if `npm run dev` fails.
# OAuth redirect example: http://localhost:5173/oauth/google-brandops.html

# Public HTTPS URL to hosted privacy-policy.html (Chrome Web Store + Welcome / Settings links).
# VITE_PRIVACY_POLICY_URL=https://your-org.github.io/brandops/privacy-policy.html

# Publisher OAuth client IDs (optional; Welcome shows sign-in without pasting IDs in Settings).
# For hosted web (Vercel, etc.), register these redirect URLs on each provider:
#   https://YOUR_DEPLOYMENT/oauth/google-brandops.html
#   https://YOUR_DEPLOYMENT/oauth/github-brandops.html
#   https://YOUR_DEPLOYMENT/oauth/linkedin-brandops.html
# Extension builds still use the chrome-extension:// redirect from chrome.identity (see Settings).
# VITE_GOOGLE_CLIENT_ID=
# VITE_GITHUB_CLIENT_ID=
# VITE_LINKEDIN_CLIENT_ID=
#
# Alternative without rebuilding: edit public/brandops-oauth-public.json on the deployed site (googleClientId, etc.).
# Production requires federated sign-in (extension chrome.identity and/or VITE_* OAuth client IDs for web popup flow).

# --- Hosted preview only (Vercel demos) — omit for Chrome Web Store production builds ---
# VITE_VERCEL_PREVIEW_SIGNIN=1
# Shared secret (8+ chars). Magic link: https://YOUR_DEPLOYMENT/welcome.html?preview_magic=YOUR_SECRET
# VITE_PREVIEW_MAGIC_TOKEN=your-long-random-string
# Optional: one-click sign-in without a token (private demos only — anyone with the URL can enter).
# VITE_PREVIEW_OPEN_SIGNIN=1
#
# Load cockpit from site root / index without OAuth (seed data). Use on Vercel preview only.
# VITE_PREVIEW_COCKPIT_UNGATED=1
