# Copy to ".env.local" in the repo root (gitignored) for local OAuth and other Vite secrets.
# See docs/chrome-web-store-listing.md for redirect URIs and store listing copy.

# Public HTTPS URL to hosted privacy-policy.html (Chrome Web Store + Welcome / Settings links).
# VITE_PRIVACY_POLICY_URL=https://your-org.github.io/brandops/privacy-policy.html

# Publisher OAuth client IDs (optional; Welcome shows sign-in without pasting IDs in Settings).
# VITE_GOOGLE_CLIENT_ID=
# VITE_GITHUB_CLIENT_ID=
# VITE_LINKEDIN_CLIENT_ID=

# Demo / Vercel preview only: enables "Enter demo mode" without chrome.identity (never use for Chrome Web Store build).
# VITE_DEMO_BYPASS=1
