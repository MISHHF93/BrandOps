# Loaded only for `npm run dev` — not used by `vite build` (production).
# Dev URL: http://localhost:5173 (strict; stop any other process on 5173 before npm run dev).
# Shows the “Hosted preview (Vercel)” card on Welcome so local dev matches Vercel demo flows.
VITE_VERCEL_PREVIEW_SIGNIN=1
VITE_PREVIEW_OPEN_SIGNIN=1
# Match hosted preview: dashboard is the default surface; no OAuth gate in dev.
VITE_PREVIEW_COCKPIT_UNGATED=1
